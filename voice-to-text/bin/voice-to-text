#!/bin/bash
# Voice-to-text script using Whisper
# Records audio, transcribes with Whisper, copies to clipboard

set -e

VENV_PATH="$HOME/voice-to-text-env"
AUDIO_FILE="/tmp/voice-recording-$$.wav"
MODEL="${WHISPER_MODEL:-base}"  # Options: tiny, base, small, medium, large

cleanup() {
    rm -f "$AUDIO_FILE" 2>/dev/null
}
trap cleanup EXIT

# Check dependencies
if [ ! -d "$VENV_PATH" ]; then
    echo "Error: Virtual environment not found at $VENV_PATH"
    exit 1
fi

if ! command -v arecord &> /dev/null; then
    echo "Error: arecord not found. Install with: sudo apt install alsa-utils"
    exit 1
fi

echo "Recording... Press Ctrl+C when done speaking."
echo ""

# Record audio (16kHz mono WAV for Whisper)
arecord -f S16_LE -r 16000 -c 1 "$AUDIO_FILE" 2>/dev/null || true

echo ""
echo "Transcribing..."

# Activate venv and run whisper
source "$VENV_PATH/bin/activate"
RESULT=$(whisper "$AUDIO_FILE" --model "$MODEL" --language en --output_format txt --output_dir /tmp 2>/dev/null)

# Get the transcription from the output file
TEXT_FILE="/tmp/$(basename "$AUDIO_FILE" .wav).txt"
if [ -f "$TEXT_FILE" ]; then
    TRANSCRIPTION=$(cat "$TEXT_FILE")
    rm -f "$TEXT_FILE"

    if [ -n "$TRANSCRIPTION" ]; then
        echo "$TRANSCRIPTION" | xclip -selection clipboard
        echo "Transcription copied to clipboard:"
        echo "---"
        echo "$TRANSCRIPTION"
        echo "---"
        echo ""
        echo "Paste with Ctrl+V or middle-click"
    else
        echo "No speech detected."
    fi
else
    echo "Transcription failed."
    exit 1
fi
